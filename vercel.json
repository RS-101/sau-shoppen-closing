{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "@vercel/php"
    },
    {
      "src": "js/*.php",
      "use": "@vercel/php"
    },
    {
      "src": "pages/*.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "^/js/(.*\\.php)$",
      "dest": "/js/$1"
    },
    {
      "src": "^/pages/(.*\\.php)$",
      "dest": "/pages/$1"
    }
  ]
}